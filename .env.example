# =========================================================
# Auth Module Backend - Environment Template
# Copy this file to .env and fill values for your machine.
# NEVER commit .env to GitHub.
# =========================================================

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Database
# Local example:
# MONGODB_URI=mongodb://127.0.0.1:27017/auth_module
# Atlas example (DO NOT commit real username/password):
MONGODB_URI=

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=1h

# Google OAuth
GOOGLE_CLIENT_ID=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Brevo Email (optional - in dev/test you can keep blank)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@example.com