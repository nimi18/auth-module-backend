{
  "name": "auth-module-backend",
  "version": "1.1.0",
  "description": "Freelance-ready authentication service built with Node.js, Express, and MongoDB",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "cross-env NODE_ENV=test mocha \"./test/**/*.test.js\" --timeout 20000 --exit",
    "test:watch": "cross-env NODE_ENV=test mocha --require test/setup.js \"test/**/*.test.js\" --timeout 20000 --watch"
  },
  "keywords": [
    "auth",
    "authentication",
    "jwt",
    "oauth",
    "nodejs",
    "express",
    "mongodb",
    "microservice",
    "swagger",
    "freelance-ready"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.20.1",
    "nodemailer": "^7.0.10",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
